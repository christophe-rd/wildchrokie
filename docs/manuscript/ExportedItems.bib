@article{green_limits_2022,
  title = {The Limits of Forest Carbon Sequestration},
  author = {Green, Julia K. and Keenan, Trevor F.},
  year = 2022,
  month = may,
  journal = {Science},
  volume = {376},
  number = {6594},
  pages = {692--693},
  issn = {0036-8075, 1095-9203},
