@article{reich_carbonnitrogen_2006,
	title = {Carbon-{Nitrogen} {Interactions} in {Terrestrial} {Ecosystems} in {Response} to {Rising} {Atmospheric} {Carbon} {Dioxide}},
	volume = {37},
	issn = {1543-592X, 1545-2069},
	url = {https://www.annualreviews.org/doi/10.1146/annurev.ecolsys.37.091305.110039},
	doi = {10.1146/annurev.ecolsys.37.091305.110039},
	abstract = {Interactions involving carbon (C) and nitrogen (N) likely modulate terrestrial ecosystem responses to elevated atmospheric carbon dioxide (CO
              2
              ) levels at scales from the leaf to the globe and from the second to the century. In particular, response to elevated CO
              2
              may generally be smaller at low relative to high soil N supply and, in turn, elevated CO
              2
              may influence soil N processes that regulate N availability to plants. Such responses could constrain the capacity of terrestrial ecosystems to acquire and store C under rising elevated CO
              2
              levels. This review highlights the theory and empirical evidence behind these potential interactions. We address effects on photosynthesis, primary production, biogeochemistry, trophic interactions, and interactions with other resources and environmental factors, focusing as much as possible on evidence from long-term field experiments.},
	language = {en},
