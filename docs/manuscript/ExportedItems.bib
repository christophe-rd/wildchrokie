}

@article{moore_developmental_2014,
	title = {Developmental {Models} for {Estimating} {Ecological} {Responses} to {Environmental} {Variability}: {Structural}, {Parametric}, and {Experimental} {Issues}},
	volume = {62},
	copyright = {http://www.springer.com/tdm},
	issn = {0001-5342, 1572-8358},
	shorttitle = {Developmental {Models} for {Estimating} {Ecological} {Responses} to {Environmental} {Variability}},
	url = {http://link.springer.com/10.1007/s10441-014-9209-9},
	doi = {10.1007/s10441-014-9209-9},
	abstract = {Developmental models that account for the metabolic effect of temperature variability on poikilotherms, such as degree-day models, have been widely used to study organism emergence, range and development, particularly in agricultural and vector-borne disease contexts. Though simple and easy to use, structural and parametric issues can influence the outputs of such models, often substantially. Because the underlying assumptions and limitations of these models have rarely been considered, this paper reviews the structural, parametric, and experimental issues that arise when using degree-day models, including the implications of particular structural or parametric choices, as well as assumptions that underlie commonly used models. Linear and nonlinear developmental functions are compared, as are common methods used to incorporate temperature thresholds and calculate daily degree-days. Substantial differences in predicted emergence time arose when using linear vs. non-linear developmental functions to model the emergence time in a model organism. The optimal method for calculating degree-days depends upon where key temperature threshold parameters fall relative to the daily minimum and maximum temperatures, as well as the shape of the daily temperature curve. No method is shown to be universally superior, though one commonly used method, the daily average method, consistently provides accurate results. The sensitivity of model projections to these methodological issues highlights the need to make structural and parametric selections based on a careful consideration of the specific biological response of the organism under study, and the specific temperature conditions of the geographic regions of interest. When degree-day model limitations are considered and model assumptions met, the models can be a powerful tool for studying temperature-dependent development.},
	language = {en},
	number = {1},
	urldate = {2025-09-30},
	journal = {Acta Biotheoretica},
	author = {Moore, Julia L. and Remais, Justin V.},
	month = mar,
	year = {2014},
	pages = {69--90},
	file = {PDF:/Users/christophe_rouleau-desrochers/Zotero/storage/AT7G6C9C/Moore and Remais - 2014 - Developmental Models for Estimating Ecological Responses to Environmental Variability Structural, P.pdf:application/pdf},
}

