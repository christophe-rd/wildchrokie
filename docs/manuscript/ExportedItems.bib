@article{wolkovich_progress_2014,
  title = {Progress towards an Interdisciplinary Science of Plant Phenology: Building Predictions across Space, Time and Species Diversity},
  shorttitle = {Progress towards an Interdisciplinary Science of Plant Phenology},
  author = {Wolkovich, Elizabeth M. and Cook, Benjamin I. and Davies, T. Jonathan},
  year = 2014,
  journal = {New Phytologist},
  volume = {201},
  number = {4},
  pages = {1156--1162},
  issn = {1469-8137},
  doi = {10.1111/nph.12599},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/nph.12599},
  urldate = {2024-09-12},
  abstract = {Climate change has brought renewed interest in the study of plant phenology -- the timing of life history events. Data on shifting phenologies with warming have accumulated rapidly, yet research has been comparatively slow to explain the diversity of phenological responses observed across latitudes, growing seasons and species. Here, we outline recent efforts to synthesize perspectives on plant phenology across the fields of ecology, climate science and evolution. We highlight three major axes that vary among these disciplines: relative focus on abiotic versus biotic drivers of phenology, on plastic versus genetic drivers of intraspecific variation, and on cross-species versus autecological approaches. Recent interdisciplinary efforts, building on data covering diverse species and climate space, have found a greater role of temperature in controlling phenology at higher latitudes and for early-flowering species in temperate systems. These efforts have also made progress in understanding the tremendous diversity of responses across species by incorporating evolutionary relatedness, and linking phenological flexibility to invasions and plant performance. Future research with a focus on data collection in areas outside the temperate mid-latitudes and across species' ranges, alongside better integration of how risk and investment shape plant phenology, offers promise for further progress.},
  copyright = {\copyright{} 2013 The Authors. New Phytologist \copyright{} 2013 New Phytologist Trust},
  langid = {english},
  keywords = {climate change,cues,investment,local adaptation,phenology,plant ecology,plasticity,risk},
  file = {/Users/christophe_rouleau-desrochers/Zotero/storage/533GA9A5/Wolkovich et al. - 2014 - Progress towards an interdisciplinary science of p.pdf;/Users/christophe_rouleau-desrochers/Zotero/storage/DTD6PZUP/Wolkovich et al. - 2014 - Progress towards an interdisciplinary science of plant phenology building predictions across space,.pdf;/Users/christophe_rouleau-desrochers/Zotero/storage/X5IVR9XB/nph.html}
}

@article{wolkovich_simple_2021,
