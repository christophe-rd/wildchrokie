  issn = {2041-1723},
  doi = {10.1038/s41467-017-02690-y},
  url = {https://www.nature.com/articles/s41467-017-02690-y},
  urldate = {2025-06-21},
  abstract = {Abstract                            While climate warming reduces the occurrence of frost events, the warming-induced lengthening of the growing season of plants in the Northern Hemisphere may actually induce more frequent frost days during the growing season (GSFDs, days with minimum temperature\,{$<$}\,0\,{$^\circ$}C). Direct evidence of this hypothesis, however, is limited. Here we investigate the change in the number of GSFDs at latitudes greater than 30{$^\circ$} N using remotely-sensed and in situ phenological records and three minimum temperature (               T               min               ) data sets from 1982 to 2012. While decreased GSFDs are found in northern Siberia, the Tibetan Plateau, and northwestern North America (mainly in autumn), \textasciitilde 43\% of the hemisphere, especially in Europe, experienced a significant increase in GSFDs between 1982 and 2012 (mainly during spring). Overall, regions with larger increases in growing season length exhibit larger increases in GSFDs. Climate warming thus reduces the total number of frost days per year, but GSFDs nonetheless increase in many areas.},
  langid = {english},
  file = {/Users/christophe_rouleau-desrochers/Zotero/storage/Y4BJ9A52/Liu et al. - 2018 - Extension of the growing season increases vegetati.pdf}
}

