@article{garcia-hidalgo_capturing_2022,
  title = {{{CaptuRING}}: {{A}} Do-it-yourself Tool for Wood Sample Digitization},
  shorttitle = {{{CaptuRING}}},
  author = {Garc{\'i}a-Hidalgo, Miguel and Garc{\'i}a-Pedrero, {\'A}ngel and Col{\'o}n, Daniel and Sang{\"u}esa-Barreda, Gabriel and Garc{\'i}a-Cervig{\'o}n, Ana I. and L{\'o}pez-Molina, Juan and Hern{\'a}ndez-Alonso, H{\'e}ctor and Rozas, Vicente and Olano, Jos{\'e} Miguel and Alonso-G{\'o}mez, V{\'i}ctor},
  year = 2022,
  month = jun,
  journal = {Methods in Ecology and Evolution},
  volume = {13},
  number = {6},
  pages = {1185--1191},
  issn = {2041-210X, 2041-210X},
  doi = {10.1111/2041-210X.13847},
  url = {https://besjournals.onlinelibrary.wiley.com/doi/10.1111/2041-210X.13847},
  urldate = {2025-11-05},
  abstract = {Abstract                                                                Standard procedures to obtain high-quality images of wood samples have become a bottleneck in the digitization of dendrochronology. Digitization is currently dominated by flatbed scanners, but the use of these devices is limited by sample length and surface flatness. Although several solutions based on digital photography have been published, they lack effective digitization processes or are too expensive to be widely adopted.                                                     Free open-source software and hardware has emerged as an alternative to create research tools that combine reduced costs with high reliability. Here we present CaptuRING, an open-source tool for wood sample digitization combining a do-it-yourself hardware based on Arduino\textregistered{} with a DSLR camera and a free open-source software with an easy-to-use graphical user interface.                                                     We compared CaptuRing with image acquisition from a standard flatbed scanner Epson\textregistered{} V750PRO. CaptuRING outperforms scanner image resolution and sharpness, while it removes sample size limitations. Moreover, CaptuRing performs this task in less than half of the time needed by Epson\textregistered{} V750PRO flatbed scanner.                                                     CaptuRING emerges as a reliable and low-cost tool to capture high-resolution images of wood samples boosting current digitization processes. The combination of free open software and hardware empowers dendrochronology to advance in wood sample digitization.},
  langid = {english},
  file = {/Users/christophe_rouleau-desrochers/Zotero/storage/6HSX5NGY/García‐Hidalgo et al. - 2022 - CaptuRING A do‐it‐yourself tool for wood sample digitization.pdf}
}

@article{gazol_forest_2018,
  title = {Forest Resilience to Drought Varies across Biomes},
  author = {Gazol, Antonio and Camarero, Jesus Julio and Vicente-Serrano, Sergio M. and S{\'a}nchez-Salguero, Ra{\'u}l and Guti{\'e}rrez, Emilia and De Luis, Martin and Sang{\"u}esa-Barreda, Gabriel and Novak, Klemen and Rozas, Vicente and T{\'i}scar, Pedro A. and Linares, Juan C. and Mart{\'i}n-Hern{\'a}ndez, Natalia and Mart{\'i}nez Del Castillo, Edurne and Ribas, Montse and Garc{\'i}a-Gonz{\'a}lez, Ignacio and Silla, Fernando and Camis{\'o}n, Alvaro and G{\'e}nova, Mar and Olano, Jos{\'e} M. and Longares, Luis A. and Hevia, Andrea and Tom{\'a}s-Burguera, Miquel and Galv{\'a}n, J. Diego},
  year = 2018,
  month = may,
  journal = {Global Change Biology},
  volume = {24},
  number = {5},
  pages = {2143--2158},
  issn = {1354-1013, 1365-2486},
  doi = {10.1111/gcb.14082},
  url = {https://onlinelibrary.wiley.com/doi/10.1111/gcb.14082},
  urldate = {2025-10-22},
  abstract = {Abstract                            Forecasted increase drought frequency and severity may drive worldwide declines in forest productivity. Species-level responses to a drier world are likely to be influenced by their functional traits. Here, we analyse forest resilience to drought using an extensive network of tree-ring width data and satellite imagery. We compiled proxies of forest growth and productivity (               TRW               i, absolutely dated ring-width indices;               NDVI               , Normalized Difference Vegetation Index) for 11 tree species and 502 forests in Spain corresponding to Mediterranean, temperate, and continental biomes. Four different components of forest resilience to drought were calculated based on               TRW               i and               NDVI               data before, during, and after four major droughts (1986, 1994--1995, 1999, and 2005), and pointed out that               TRW               i data were more sensitive metrics of forest resilience to drought than               NDVI               data. Resilience was related to both drought severity and forest composition. Evergreen gymnosperms dominating semi-arid Mediterranean forests showed the lowest resistance to drought, but higher recovery than deciduous angiosperms dominating humid temperate forests. Moreover, semi-arid gymnosperm forests presented a negative temporal trend in the resistance to drought, but this pattern was absent in continental and temperate forests. Although gymnosperms in dry Mediterranean forests showed a faster recovery after drought, their recovery potential could be constrained if droughts become more frequent. Conversely, angiosperms and gymnosperms inhabiting temperate and continental sites might have problems to recover after more intense droughts since they resist drought but are less able to recover afterwards.},
  copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
  langid = {english},
  file = {/Users/christophe_rouleau-desrochers/Zotero/storage/PDRFZ4SD/Gazol et al. - 2018 - Forest resilience to drought varies across biomes.pdf}
}

