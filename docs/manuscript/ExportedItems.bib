@article{liu_extension_2018,
  title = {Extension of the Growing Season Increases Vegetation Exposure to Frost},
  author = {Liu, Qiang and Piao, Shilong and Janssens, Ivan A. and Fu, Yongshuo and Peng, Shushi and Lian, Xu and Ciais, Philippe and Myneni, Ranga B. and Pe{\~n}uelas, Josep and Wang, Tao},
  year = 2018,
  month = jan,
  journal = {Nature Communications},
  volume = {9},
