@article{campbell_blue_2007,
  title = {Blue Intensity in {{{\emph{Pinus}}}}{\emph{ Sylvestris}} Tree-Rings: Developing a New Palaeoclimate Proxy},
  shorttitle = {Blue Intensity in {{{\emph{Pinus}}}}{\emph{ Sylvestris}} Tree-Rings},
  author = {Campbell, Rochelle and McCarroll, Danny and Loader, Neil J. and Grudd, H{\aa}kan and Robertson, Iain and Jalkanen, Risto},
  year = 2007,
  month = sep,
  journal = {The Holocene},
  volume = {17},
  number = {6},
  pages = {821--828},
  issn = {0959-6836, 1477-0911},
  doi = {10.1177/0959683607080523},
  url = {https://journals.sagepub.com/doi/10.1177/0959683607080523},
  urldate = {2025-11-05},
  abstract = {Minimum blue intensity measurements of resin-extracted Pinus sylvestris (L.) samples, conducted using a flat-bed scanner and commercially available software, are shown to provide a robust and reliable surrogate for maximum latewood density. Blue intensity data from 15 trees, from three stands, are reported relative to a standard blue-scale in a manner similar to grey-scale calibration in x-ray densitometry. The resulting time series are highly correlated with x-ray densitometry data generated from the same samples and preserve the same high level of signal strength. Sensitivity to summer climate variables is similar to that identified in the relative density record, demonstrating that minimum blue intensity can also be used for the study of climate change. While not a replacement for the powerful range of x-ray densitometry techniques, blue intensity provides an inexpensive and accessible alternative for accessing palaeoclimatic information.},
  copyright = {https://journals.sagepub.com/page/policies/text-and-data-mining-license},
  langid = {english}
}

@article{campbell_producing_2014,
  title = {Producing {{Targets}} for {{Conservation}}: {{Science}} and {{Politics}} at the {{Tenth Conference}} of the {{Parties}} to the {{Convention}} on {{Biological Diversity}}},
  shorttitle = {Producing {{Targets}} for {{Conservation}}},
  author = {Campbell, Lisa M. and Hagerman, Shannon and Gray, Noella J.},
  year = 2014,
  month = aug,
  journal = {Global Environmental Politics},
  volume = {14},
  number = {3},
  pages = {41--63},
  issn = {1526-3800, 1536-0091},
  doi = {10.1162/GLEP_a_00238},
  url = {https://direct.mit.edu/glep/article/14/3/41-63/14679},
  urldate = {2025-10-31},
  abstract = {Biodiversity targets were prominent at the Tenth Conference of the Parties to the Convention on Biological Diversity (CBD). Having failed to reach the CBD's 2010 target, delegates debated the nature of targets, details of specific targets, and how to avoid failure in 2020. As part of a group of seventeen researchers conducting a collaborative event ethnography at COP10, we draw on observations made during negotiations of the CBD Strategic Plan and at side events to analyze the production of the 2020 targets. Once adopted, targets become ``naturalized,'' detached from the negotiations that produced them. Drawing on insights from science and technology studies, we analyze the interaction of science and politics during negotiations and discuss what targets do within the CBD and the broader global conservation governance network.},
  langid = {english}
}

