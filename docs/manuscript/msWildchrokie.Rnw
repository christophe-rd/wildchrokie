# Helper function to report results more efficiently:
fmt_stat <- function(df, spp) {
  row <- df[df$spp_name == spp, ]
  if (nrow(row) != 1) {
    stop("Expected exactly 1 row for '", spp, "', got ", nrow(row))
  }
  sprintf("%.2f\\%%, (UI: %.2f, %.2f)", row$mean, row$p5, row$p95)
}

mean_rw_mm <- aggregate(lengthMM ~ spp_num, data = emp, FUN = mean)
names(mean_rw_mm)[2] <- "mean_rw_mm"

