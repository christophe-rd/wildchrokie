    fmt_split(site_df2_GDD), fmt_split(ayear_df2_GDD), fmt_split(aspp_df2_GDD)
  ),
  rbind(
    fmt_split(a_df2_GSL), fmt_split(sigma_df2_GSL), fmt_split(bspp_df2_GSL),
