options(digits = 2)

a_df_GDD      <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_a.csv")
sigma_df_GDD  <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_sigma.csv")
bspp_df_GDD   <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_bspp.csv")
aspp_df_GDD   <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_aspp.csv")
site_df_GDD   <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_site.csv")
ayear_df_GDD  <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_ayear.csv")

bspp_df_GDD$spp_name   <- emp$latbi[match(bspp_df_GDD$spp, emp$spp_num)]
site_df_GDD$site_name  <- emp$site[match(site_df_GDD$site, emp$site_num)]
aspp_df_GDD$spp_name   <- emp$latbi[match(aspp_df_GDD$spp, emp$spp_num)]
ayear_df_GDD$year_name <- emp$year[match(ayear_df_GDD$year, emp$year_num)]

param_labels_GDD <- c(
  "$\\alpha$",
  "$\\sigma_{\\alpha_{treeid}}$", "$\\sigma_{\\alpha_{prov}}$", "$\\sigma_{y}$",
  paste0("$\\beta_{species_{",   bspp_df_GDD$spp_name,  "}}$"),
  paste0("$\\alpha_{prov_{", site_df_GDD$site_name, "}}$"),
  paste0("$\\alpha_{year_{", ayear_df_GDD$year_name, "}}$"),
  paste0("$\\alpha_{species_{",  aspp_df_GDD$spp_name,  "}}$")
)

fmt_split <- function(df) {
  data.frame(
    Mean = sprintf("%.2f", df$mean),
    `5\\%` = sprintf("%.2f", df$p5),
    `25\\%` = sprintf("%.2f", df$p25),
    `75\\%` = sprintf("%.2f", df$p75),
    `95\\%` = sprintf("%.2f", df$p95),
    check.names = FALSE
  )
}

combined_GDD <- data.frame(
  "Parameter" = param_labels_GDD,
  rbind(
    fmt_split(a_df_GDD), fmt_split(sigma_df_GDD), fmt_split(bspp_df_GDD),
    fmt_split(site_df_GDD), fmt_split(ayear_df_GDD), fmt_split(aspp_df_GDD)
  ),
  check.names = FALSE
)

colnames(combined_GDD) <- c("Parameter", "Mean", "5\\%", "25\\%", "75\\%", "95\\%")

tab_GDD <- xtable(combined_GDD,
              caption = "Summary output of each parameter for the growing degree days (GDD) predictor of ring width (log(mm)). We report estimates as mean and 90\\% and 50\\% uncertainty intervals. See `Data analyses' in Methods section for more details.",
              label = "tab:tab_GDD")

print(tab_GDD,
      include.rownames = FALSE,
      sanitize.text.function = identity,
      caption.placement = "top",
      hline.after = c(-1, 0, nrow(combined_GDD)),
      floating = TRUE
)
@


