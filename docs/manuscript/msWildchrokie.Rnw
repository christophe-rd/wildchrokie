  ),
  rbind(
    fmt_split(a_df2_SOS), fmt_split(sigma_df2_SOS), fmt_split(bspp_df2_SOS),
    fmt_split(site_df2_SOS), fmt_split(ayear_df2_SOS), fmt_split(aspp_df2_SOS)
  ),
  rbind(
    fmt_split(a_df2_EOS), fmt_split(sigma_df2_EOS), fmt_split(bspp_df2_EOS),
    fmt_split(site_df2_EOS), fmt_split(ayear_df2_EOS), fmt_split(aspp_df2_EOS)
  ),
  check.names = FALSE
)

colnames(combined) <- c("Parameter",
                         "Mean", "5\\%", "95\\%",
                         "Mean", "5\\%", "95\\%",
                         "Mean", "5\\%", "95\\%",
                         "Mean", "5\\%", "95\\%")

tab <- xtable(combined,
              caption = "Summary output of each parameter from our four predictors, using ring width (log(mm)) as the response variable. We report estimates as mean and 90\\% uncertainty intervals across our four different predictors (GDD: growing degree days, GSL: growing season length, SOS: start of season and EOS: end of season). See `Data analyses' in Methods section for more details.",
              label = "tab:tab_all")

addtorow <- list()
addtorow$pos <- list(-1, -1)
addtorow$command <- c(
  paste0(
    "\\hline\n",
    "& \\multicolumn{3}{c}{GDD} & \\multicolumn{3}{c}{GSL} & \\multicolumn{3}{c}{SOS} & \\multicolumn{3}{c}{EOS} \\\\\n"
  ),
  paste0(
    "Parameter & Mean & 5\\% & 95\\% & Mean & 5\\% & 95\\% & Mean & 5\\% & 95\\% & Mean & 5\\% & 95\\% \\\\\n"
  )
)

print(tab,
      include.rownames = FALSE,
      include.colnames = FALSE,
      sanitize.text.function = identity,
      caption.placement = "top",
      add.to.row = addtorow,
      hline.after = c(-1, 0, nrow(combined)),
      # tabular.environment = "longtable",
      floating = TRUE
)
@

<<Table BAI Wildchrokie, results='asis', echo = FALSE>>=
options(digits = 2)
a_df2_BAI      <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_a_BAI.csv")
sigma_df2_BAI  <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_sigma_BAI.csv")
bspp_df2_BAI   <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_bspp_BAI.csv")
treeid_df2_BAI <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_treeid_BAI.csv")
aspp_df2_BAI   <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_aspp_BAI.csv")
site_df2_BAI   <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_site_BAI.csv")
ayear_df2_BAI  <- read.csv("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/output/GM_GDDparam_ayear_BAI.csv")

bspp_df2_BAI$spp_name <- emp$latbi[match(bspp_df2_BAI$spp, emp$spp_num)]
site_df2_BAI$site_name <- emp$site[match(site_df2_BAI$site, emp$site_num)]
aspp_df2_BAI$spp_name <- emp$latbi[match(aspp_df2_BAI$spp, emp$spp_num)]
ayear_df2_BAI$year_name <- emp$year[match(ayear_df2_BAI$year, emp$year_num)]

alpha <- data.frame(
  Parameter = c("$\\alpha$"),
  Mean = sprintf("%.2f", a_df2_BAI$mean),
  P5   = sprintf("%.2f", a_df2_BAI$p5),
  P95  = sprintf("%.2f", a_df2_BAI$p95)
)
sigma <- data.frame(
  Parameter = c("$\\sigma_{\\alpha_{treeid}}$",
                "$\\sigma_{\\alpha_{prov}}$",
                "$\\sigma_{y}$"),
  Mean = sprintf("%.2f", sigma_df2_BAI$mean),
  P5   = sprintf("%.2f", sigma_df2_BAI$p5),
  P95  = sprintf("%.2f", sigma_df2_BAI$p95)
)
bspp <- data.frame(
  Parameter = paste0("$\\beta_{species_{", bspp_df2_BAI$spp_name, "}}$"),
  Mean = sprintf("%.2f", bspp_df2_BAI$mean),
  P5   = sprintf("%.2f", bspp_df2_BAI$p5),
  P95  = sprintf("%.2f", bspp_df2_BAI$p95)
)
aspp <- data.frame(
  Parameter = paste0("$\\alpha_{species_{", aspp_df2_BAI$spp_name, "}}$"),
  Mean = sprintf("%.2f", aspp_df2_BAI$mean),
  P5   = sprintf("%.2f", aspp_df2_BAI$p5),
  P95  = sprintf("%.2f", aspp_df2_BAI$p95)
)
site <- data.frame(
  Parameter = paste0("$\\alpha_{site_{", site_df2_BAI$site_name, "}}$"),
  Mean = sprintf("%.2f", site_df2_BAI$mean),
  P5   = sprintf("%.2f", site_df2_BAI$p5),
  P95  = sprintf("%.2f", site_df2_BAI$p95)
)
ayear <- data.frame(
  Parameter = paste0("$\\alpha_{year_{", ayear_df2_BAI$year_name, "}}$"),
  Mean = sprintf("%.2f", ayear_df2_BAI$mean),
  P5   = sprintf("%.2f", ayear_df2_BAI$p5),
  P95  = sprintf("%.2f", ayear_df2_BAI$p95)
)
binded <- rbind(alpha, sigma, bspp, site, ayear, aspp)

print(xtable(binded,
             caption = "Summary output of each parameter from our GDD (growing degree days) model, using basal area increment (log($mm^2$)) as the response variable. We report estimates as mean and 90\\% uncertainty intervals. See `Data analyses' in Methods section for more details.",
             label = "tab:BAItab"),
      include.rownames = FALSE,
      sanitize.text.function = identity,
      sanitize.colnames.function = function(x) paste0("\\textbf{", gsub("P5", "5\\\\%", gsub("P95", "95\\\\%", x)), "}"),
      caption.placement = "top")
@

<<Table percentages SOS and EOS gain, results='asis', echo = FALSE>>=
b_sosgain$spp_name <- emp$latbi[match(b_sosgain$spp, emp$spp_num)]
b_eosgain$spp_name <- emp$latbi[match(b_eosgain$spp, emp$spp_num)]

meansos <- data.frame(
  "Parameter" = paste0("$\\beta_{SOS}$"),
  "Mean" = sprintf("%.2f", b_sosgain_mu$mean),
  "5\\%" = sprintf("%.2f", b_sosgain_mu$p5),
  "95\\%" = sprintf("%.2f", b_sosgain_mu$p95)
)

meaneos <- data.frame(
  "Parameter" = paste0("$\\beta_{EOS}$"),
  "Mean" = sprintf("%.2f", b_eosgain_mu$mean),
  "5\\%" = sprintf("%.2f", b_eosgain_mu$p5),
  "95\\%" = sprintf("%.2f", b_eosgain_mu$p95)
)

sosgain <- data.frame(
  "Parameter" = paste0("$\\beta_{SOS_{", b_sosgain$spp_name, "}}$"),
  "Mean" = sprintf("%.2f", b_sosgain$mean),
  "5\\%" = sprintf("%.2f", b_sosgain$p5),
  "95\\%" = sprintf("%.2f", b_sosgain$p95)
)

eosgain <- data.frame(
  "Parameter" = paste0("$\\beta_{EOS_{", b_eosgain$spp_name, "}}$"),
  "Mean" = sprintf("%.2f", b_eosgain$mean),
  "5\\%" = sprintf("%.2f", b_eosgain$p5),
  "95\\%" = sprintf("%.2f", b_eosgain$p95)
)

binded <- rbind(meansos, meaneos, sosgain, eosgain)
colnames(binded) <- paste0("\\textbf{",c("Parameter", "Mean", "5\\%", "95\\%"),"}")

print(xtable(binded,
             caption = "Summary output ($\\beta$) of our GDD parameters, converted in \\% for a predicted extension in SOS and EOS across and for each species. We report estimates as posterior means with 90\\% uncertainty intervals.",
             label = "tab:phenogain"),
      include.rownames = FALSE,
      sanitize.text.function = identity,
      caption.placement = "top")
@

% Full vs restricted data comparison for Wildchrokie
\begin{figure}[!ht]
\includegraphics[width=1\textwidth]{../../analyses/figures/growthModelsMain/FullVSRestricted.pdf} 
\caption{Full vs most restricted datasets for the model with start of season (a-d) and end of season (d-h) as the predictor. Each panel represent the different parameters used to fit the models. $\sigma$ (a, e), $\alpha_{species}$ (c, g) and $\alpha_{year}$ (d,h) represent the ring width (log(mm)) for species and year, respectively. $\beta_{species}$ (b, f) represent the change in ring width (log(mm))/adjusted predictor, for each species (see 'Data analyses' section in Methods for more details).} 
\label{fig:wcSOSEOScomparison}
\end{figure}

% XY facetted by species GDD
\begin{figure}[!ht]
\includegraphics[width=0.8\textwidth]{../../analyses/figures/growthModelsMain/growthModelSlopesperSppFacet.pdf}
\caption{Ring width (mm) trends in response to thermal season (growing degree days). The plots are the reconstructed species estimates posterior distribution with error. The lines represent the mean of the posterior distribution and the shaded area, the 50\% UI at each predictor value. The dots are the empirical data shaped by year.}
\label{fig:wcxyGDD}
\end{figure}

% XY facetted by species GSL
\begin{figure}[!ht]
\includegraphics[width=0.8\textwidth]{../../analyses/figures/growthModelsMain/growthModelSlopesperSppFacetGSL.pdf}
\caption{Ring width trends (mm) in response to calendar season (growing season length). The plots are the reconstructed species estimates posterior distribution with error. The lines represent the mean of the posterior distribution and the shaded area, the 50\% UI at each predictor value. The dots are the empirical data shaped by year.}
\label{fig:wcxyGSL}
\end{figure}

% Figure mu atreeid full
\begin{figure}[!ht]
\includegraphics[width=0.8\textwidth]{../../analyses/figures/growthModelsMain/meanPlotGrowthGDD_treeidBYspp.pdf}
\caption{Ring width (log(mm)) deviations from the grand mean for grouping factor of the GDD model. The different tree id values represent the combined intercepts of tree id, provenance, species and averaged year intercepts. The larger dots and lines represent the species intercepts which are the species level estimates averaged across all of their tree ids. The dots are the mean of the posterior distribution and the thick and thin lines, the 50 and 90\% UI.}
\label{fig:wcmuplotatreeid}
\end{figure}

% Wildchrokie boxplot
\begin{figure}[!ht]
\includegraphics[width=1\textwidth]{../../analyses/figures/growthModelsMain/boxplotRingWidth.jpeg}
\caption{Boxplots representing the empirical data of our ring widths (mm) separated by species. The dots represent the raw data, the line is the mean and the box depicts the 50\% UI.}
\label{fig:wcboxplotRW}
\end{figure}

% Wildchrokie boxplot
\begin{figure}[!ht]
\includegraphics[width=1\textwidth]{../../analyses/figures/growthModelsMain/boxplotPredictorsAll.pdf}  
\caption{Boxplots representing the empirical data of all our predictors clustered by species, and for each year. The dots represent the raw data, the line is the mean and the box depicts the 50\% UI.}
\label{fig:wcboxplotPred}
\end{figure}

% Z-scored slope results Wildchrokie
\begin{figure}[!ht]
\includegraphics[width=0.8\textwidth]{../../analyses/figures/growthModelsMain/zscored/muALLbsppZ.pdf}
\caption{Effect size of each predictor across our four species. We depict ring width (log(mm)) change per adjusted predictor ($z$-scored; see data analyses section for more details) for each species. We report estimates as mean and 90\% uncertainty intervals (in square brackets) across our four different predictors (growing degree days, growing season length, start of season and end of season).}
\label{fig:bsppZscored}
\end{figure}

