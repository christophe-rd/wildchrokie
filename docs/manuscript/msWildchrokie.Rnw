  "$\\sigma_{\\alpha_{treeid}}$", "$\\sigma_{\\alpha_{prov}}$", "$\\sigma_{y}$",
  paste0("$\\beta_{species_{",   bspp_df_GSL$spp_name,  "}}$"),
  paste0("$\\alpha_{prov_{", site_df_GSL$site_name, "}}$"),
  paste0("$\\alpha_{year_{", ayear_df_GSL$year_name, "}}$"),
  paste0("$\\alpha_{species_{",  aspp_df_GSL$spp_name,  "}}$")
)

combined_GSL <- data.frame(
  "Parameter" = param_labels_GSL,
  rbind(
    fmt_split(a_df_GSL), fmt_split(sigma_df_GSL), fmt_split(bspp_df_GSL),
    fmt_split(site_df_GSL), fmt_split(ayear_df_GSL), fmt_split(aspp_df_GSL)
  ),
  check.names = FALSE
)

colnames(combined_GSL) <- c("Parameter", "Mean", "5\\%", "25\\%", "75\\%", "95\\%")

tab_GSL <- xtable(combined_GSL,
              caption = "Summary output of each parameter for the growing season length (GSL) predictor of ring width (log(mm)). We report estimates as mean and 90\\% and 50\\% uncertainty intervals. See `Data analyses' in Methods section for more details.",
              label = "tab:tab_GSL")

print(tab_GSL,
      include.rownames = FALSE,
      sanitize.text.function = identity,
      caption.placement = "top",
      hline.after = c(-1, 0, nrow(combined_GSL)),
      floating = TRUE
)
@

