%-------------------------------------------------------------------------------
\subsection{Growing season length and conditions}
%-------------------------------------------------------------------------------
\begin{enumerate}

% GSL length
\item Across the three years and all species, the growing season length varied from \Sexpr{min(emp$pgsGSL)} days to \Sexpr{max(emp$pgsGSL)} days. 

% GSL length
\item The year with longest growing season length on average was 
\Sexpr{aggregate(pgsGSL ~ year, emp, mean)[which.max(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),1]} 
with
\Sexpr{round(aggregate(pgsGSL ~ year, emp, mean)[which.max(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),2], 2)} days,
and the shortest was 
\Sexpr{aggregate(pgsGSL ~ year, emp, mean)[which.min(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),1]} 
with
\Sexpr{round(aggregate(pgsGSL ~ year, emp, mean)[which.min(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),2], 2)} days.

% Temperature spring
\item The hottest spring period of the three years (MAM) was
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, 
                                 climatesum$tmeanmean, NA))]} with a mean mean temperature of 
\Sexpr{round(climatesum$tmeanmean[which.max(ifelse(climatesum$period == "MAM" & 
                                 climatesum$year %in% yrwc, climatesum$tmeanmean, NA))], 2)}$^\circ$C,
and the coldest,
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc,
                                 climatesum$tmeanmean, NA))]} with a mean mean temperature of
\Sexpr{round(climatesum$tmeanmean[which.min(ifelse(climatesum$period == "MAM" &
                                 climatesum$year %in% yrwc, climatesum$tmeanmean, NA))], 2)}$^\circ$C.

% Temperature summer
\item The hottest summer period of the three years (JJA) was
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$tmeanmean, NA))]} with a mean temperature of \Sexpr{round(climatesum$tmeanmean[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$tmeanmean, NA))], 2)}$^\circ$C,
and the coldest,
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$tmeanmean, NA))]} with a mean temperature of \Sexpr{round(climatesum$tmeanmean[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$tmeanmean, NA))], 2)}$^\circ$C.

% PDSI spring
\item The driest spring period of the three years (MAM) was
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} with a PDSI value of \Sexpr{round(climatesum$pdsi[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))], 2)},
and the wettest,
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} with a PDSI value of \Sexpr{round(climatesum$pdsi[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))], 2)}.

% PDSI summer
\item The driest summer period (PDSI) of the three years (JJA) was
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} with a PDSI value of \Sexpr{round(climatesum$pdsi[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))], 2)},
and the wettest,
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} with a PDSI value of \Sexpr{round(climatesum$pdsi[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))], 2)}.

% PPT spring
\item The spring period with the highest precipitation of the three years (MAM) was
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$ppt, NA))]} with a precipitation of \Sexpr{round(climatesum$ppt[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$ppt, NA))], 2)},
and the lowest,
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$ppt, NA))]} with a precipitation of \Sexpr{round(climatesum$ppt[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$ppt, NA))], 2)}.

% PPT summer
\item The summer period with the highest precipitation of the three years (JJA) was
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$ppt, NA))]} with a precipitation of \Sexpr{round(climatesum$ppt[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$ppt, NA))], 2)},
and the lowest,
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$ppt, NA))]} with a precipitation of \Sexpr{round(climatesum$ppt[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$ppt, NA))], 2)}.
\end{enumerate}

