aspp_df5_eos <- aspp_df2_eos[, c("spp_name", "fit_aspp_per5", "fit_aspp_per25","fit_aspp_per75","fit_aspp_per95")]

site_df5 <-         site_df2[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]
site_df5_gsl <- site_df2_gsl[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]
site_df5_sos <- site_df2_sos[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]
site_df5_eos <- site_df2_eos[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]

bspp_df5 <-         bspp_df2[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]
bspp_df5_gsl <- bspp_df2_gsl[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]
bspp_df5_sos <- bspp_df2_sos[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]
bspp_df5_eos <- bspp_df2_eos[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]

climatesumfortable <- climatesum[which(climatesum$year %in% yrwc), 1:7]
