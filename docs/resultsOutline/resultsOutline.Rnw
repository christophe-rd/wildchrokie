\section{Wildchrokie}
% <><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><>
%-------------------------------------------------------------------------------
\subsection{Species, years and observations}
%-------------------------------------------------------------------------------
\begin{enumerate}
\item Wildchrokie includes four deciduous tree species from four sites, with phenological observations from 2018 to 2020. In total, our final dataset has \Sexpr{nrow(empfullsos)} leafout observations and \Sexpr{nrow(empfulleos)}. We used these observations to set the boundaries of individual-level growing seasons, which together yield \Sexpr{nrow(emp)} complete growing season observations.
\end{enumerate}

%-------------------------------------------------------------------------------
\subsection{Growing season length and conditions}
%-------------------------------------------------------------------------------
\begin{enumerate}

% GSL length and conditions
\item \Sexpr{pgsGSLagg[which.min(pgsGSLagg$pgsGSL),1]} was the shortest season by days (mean GSL $=$\Sexpr{pgsGSLagg[which.min(pgsGSLagg$pgsGSL),2]}),
with an average summer temperature of 
\Sexpr{climatesum[climatesum$period == "JJA" & climatesum$year == pgsGSLagg[which.min(pgsGSLagg$pgsGSL), 1], 5]}$^\circ$C, and a summer thermal sum of 
\Sexpr{gddsummersum[which(gddsummersum$year %in% pgsGSLagg[which.min(pgsGSLagg$pgsGSL),1]),2]} GDD. \\
\Sexpr{pgsGSLagg[which.max(pgsGSLagg$pgsGSL),1]} was the longest season by days (mean GSL $=$
\Sexpr{pgsGSLagg[which.max(pgsGSLagg$pgsGSL),2]})
with an average summer temperature of 
\Sexpr{climatesum[climatesum$period == "JJA" & climatesum$year == pgsGSLagg[which.max(pgsGSLagg$pgsGSL), 1], 5]}$^\circ$C, and a summer thermal sum of 
\Sexpr{gddsummersum[which(gddsummersum$year %in% pgsGSLagg[which.max(pgsGSLagg$pgsGSL),1]),2]} GDD. \\
\Sexpr{pgsGSLagg[order(pgsGSLagg$pgsGSL)[ceiling(nrow(pgsGSLagg)/2)], 1]} had an average GSL of \Sexpr{pgsGSLagg[order(pgsGSLagg$pgsGSL)[ceiling(nrow(pgsGSLagg)/2)], 2]} days, 
an average summer temperature of 
\Sexpr{climatesum[climatesum$period == "JJA" & climatesum$year == pgsGSLagg[order(pgsGSLagg$pgsGSL)[ceiling(nrow(pgsGSLagg)/2)], 1], 5]}$^\circ$, and summer thermal sum of 
\Sexpr{gddsummersum[which(gddsummersum$year %in% pgsGSLagg[order(pgsGSLagg$pgsGSL)[ceiling(nrow(pgsGSLagg)/2)], 1]), 2]} GDD

% SOS conditions
\item Leafout dates across all years and species varied from 
\Sexpr{min(emp$leafout)} (\Sexpr{unique(emp[emp$leafout == min(emp$leafout), 2])}) to 
\Sexpr{max(emp$leafout)} (\Sexpr{unique(emp[emp$leafout == max(emp$leafout), 2])}) and budset date varied from 
\Sexpr{min(emp$budset)} (\Sexpr{unique(emp[emp$budset == min(emp$budset), 2])}) to 
\Sexpr{max(emp$budset)} (\Sexpr{unique(emp[emp$budset == max(emp$budset), 2])}), which are the two phases that set the boundaries of the growing season.

\item \Sexpr{SOSagg[which.min(SOSagg$leafout),1]} had the earliest start of season (mean leafout date $=$
\Sexpr{SOSagg[which.min(SOSagg$leafout),2]}), and the coldest spring of the three years
(\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == SOSagg[which.min(SOSagg$leafout), 1], 5]}$^\circ$C), with a spring thermal sum of 
\Sexpr{gddspringsum[which(gddspringsum$year %in% SOSagg[which.min(SOSagg$leafout),1]),2]} GDD. \\
\Sexpr{SOSagg[which.max(SOSagg$leafout),1]} had the latest start of season (mean leafout date $=$
\Sexpr{SOSagg[which.max(SOSagg$leafout),2]}), 
and was also the warmest spring
(\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == SOSagg[which.max(SOSagg$leafout), 1], 5]}$^\circ$C), but had the lowest thermal sum of three years
(\Sexpr{gddspringsum[which(gddspringsum$year %in% SOSagg[which.max(SOSagg$leafout),1]),2]} GDD). \\
\Sexpr{SOSagg[order(SOSagg$leafout)[ceiling(nrow(SOSagg)/2)], 1]} had an average start of season of \Sexpr{SOSagg[order(SOSagg$leafout)[ceiling(nrow(SOSagg)/2)], 2]}, an average spring temperature of
\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == SOSagg[order(SOSagg$leafout)[ceiling(nrow(SOSagg)/2)], 1], 5]}$^\circ$, and the highest spring thermal sum
(\Sexpr{gddspringsum[which(gddspringsum$year %in% SOSagg[order(SOSagg$leafout)[ceiling(nrow(SOSagg)/2)], 1]), 2]} GDD).

% SOS by species 
\item On average, the earliest leafout date was in 2019 for all species (\Ainc: \Sexpr{min(leafoutbyyr$leafout[leafoutbyyr$latbi == "Alnus incana"])}, 
B alleghaniensis: \Sexpr{min(leafoutbyyr$leafout[leafoutbyyr$latbi == "Betula alleghaniensis"])}, 
\Bpap: \Sexpr{min(leafoutbyyr$leafout[leafoutbyyr$latbi == "Betula papyrifera"])} and 
\Bpop: \Sexpr{min(leafoutbyyr$leafout[leafoutbyyr$latbi == "Betula populifolia"])}), and the latest was in 2020 (
\Ainc: \Sexpr{max(leafoutbyyr$leafout[leafoutbyyr$latbi == "Alnus incana"])}, 
B alleghaniensis: \Sexpr{max(leafoutbyyr$leafout[leafoutbyyr$latbi == "Betula alleghaniensis"])}, 
\Bpap: \Sexpr{max(leafoutbyyr$leafout[leafoutbyyr$latbi == "Betula papyrifera"])} and 
\Bpop: \Sexpr{max(leafoutbyyr$leafout[leafoutbyyr$latbi == "Betula populifolia"])}).
No species was consistently the earliest nor the latest to leafout.

% EOS condition
\item \Sexpr{EOSagg[which.min(EOSagg$budset),1]} had the earliest end of season (mean budset date $=$ \Sexpr{EOSagg[which.min(EOSagg$budset),2]}), and was coldest autumn (average autumn temperature $=$
\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == EOSagg[which.min(EOSagg$budset), 1], 5]}$^\circ$C), with a autumn thermal sum of
\Sexpr{gddspringsum[which(gddspringsum$year %in% EOSagg[which.min(EOSagg$budset),1]),2]} GDD. \\
\Sexpr{EOSagg[which.max(EOSagg$budset),1]} had the latest end of season (mean budset date $=$ \Sexpr{EOSagg[which.max(EOSagg$budset),2]}), and was the warmest autumn (average autumn temperature $=$
\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == EOSagg[which.max(EOSagg$budset), 1], 5]}$^\circ$C) with the lowest thermal sum
(\Sexpr{gddspringsum[which(gddspringsum$year %in% EOSagg[which.max(EOSagg$budset),1]),2]} GDD). \\
\Sexpr{EOSagg[order(EOSagg$budset)[ceiling(nrow(EOSagg)/2)], 1]} had an average end of season of \Sexpr{EOSagg[order(EOSagg$budset)[ceiling(nrow(EOSagg)/2)], 2]}, an average autumn temperature of 
\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == EOSagg[order(EOSagg$budset)[ceiling(nrow(EOSagg)/2)], 1], 5]}$^\circ$, 
and had the highest thermal sum of the three years (\Sexpr{gddspringsum[which(gddspringsum$year %in% EOSagg[order(EOSagg$budset)[ceiling(nrow(EOSagg)/2)], 1]), 2]} GDD).

% EOS by species 
\item On average, the earliest budset date was in 2019 for \Ainc 
(\Sexpr{min(budsetbyyr$budset[budsetbyyr$latbi == "Alnus incana"])}) and 
\Ball (\Sexpr{min(budsetbyyr$budset[budsetbyyr$latbi == "Betula alleghaniensis"])}), but in 2018 for
\Bpap (\Sexpr{min(budsetbyyr$budset[budsetbyyr$latbi == "Betula papyrifera"])}) and 
\Bpop (\Sexpr{min(budsetbyyr$budset[budsetbyyr$latbi == "Betula populifolia"])}). 
The latest budset date for all species was in 2020
(\Ainc: \Sexpr{max(budsetbyyr$budset[budsetbyyr$latbi == "Alnus incana"])}, 
\Ball: \Sexpr{max(budsetbyyr$budset[budsetbyyr$latbi == "Betula alleghaniensis"])}, 
\Bpap: \Sexpr{max(budsetbyyr$budset[budsetbyyr$latbi == "Betula papyrifera"])} and 
\Bpop: \Sexpr{max(budsetbyyr$budset[budsetbyyr$latbi == "Betula populifolia"])}).
No species was consistently the earliest nor the latest to set buds.

% PDSI spring
\item The driest spring of the three years (MAM) (3-month averaged PDSI index) was
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} with a PDSI value of 
\Sexpr{climatesum$pdsi[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]}, and a cumulative precipitation of 
\Sexpr{climatesum$ppt[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} mm.
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} was the least dry spring with a PDSI value of 
\Sexpr{climatesum$pdsi[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} and a cumulative precipitation of \Sexpr{climatesum$ppt[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} mm.

% PDSI summer
\item \Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} had the driest summer (JJA) with a PDSI value of 
\Sexpr{climatesum$pdsi[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]}, and a cumulative precipitation of 
\Sexpr{climatesum$ppt[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} mm.
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} was the least dry summer with a PDSI value of 
\Sexpr{climatesum$pdsi[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} and a cumulative precipitation of 
\Sexpr{climatesum$ppt[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrwc, climatesum$pdsi, NA))]} mm.

% Drought occurence
\item \Sexpr{unique(moderatedrought[which(moderatedrought$month <10 & moderatedrought$month > 2 & moderatedrought$year %in% yrwc), 1])} is the only year a with period of moderate drought ($PDSI [-3, -2]$) which was from 
\Sexpr{moderatedrought[which(moderatedrought$month <10 & moderatedrought$month > 2 & moderatedrought$year %in% yrwc), 11][1]} through 
\Sexpr{moderatedrought[which(moderatedrought$month <10 & moderatedrought$month > 2 & moderatedrought$year %in% yrwc), 11][3]}. Throughout the three years,
\Sexpr{unique(severedrought[which(severedrought$month <10 & severedrought$month > 2 & severedrought$year %in% yrwc), 11])} of 
\Sexpr{unique(severedrought[which(severedrought$month <10 & severedrought$month > 2 & severedrought$year %in% yrwc), 1])} was the only period with a severe drought ($PDSI < -3$) 

\end{enumerate}

%-------------------------------------------------------------------------------
\subsection{Ring widths}
%-------------------------------------------------------------------------------
\begin{enumerate}
\item The ring widths of our species vary from \Sexpr{min(emp$lengthMM)} mm to \Sexpr{max(emp$lengthMM)} mm. 
\item Ring widths for \Ball were the smallest and varied from \Sexpr{rwsum[2,2]} mm to \Sexpr{rwsum[2,3]} mm, and 
\Bpop had the largest rings which spanned from 
\Sexpr{rwsum[4,2]} mm to \Sexpr{rwsum[4,3]} mm on average.
\Ainc (\Sexpr{rwsum[1,2]} mm to \Sexpr{rwsum[1,3]} mm) and 
\Bpap were quite similar (\Sexpr{rwsum[3,2]} mm to \Sexpr{rwsum[3,3]} mm).
\end{enumerate}

%-------------------------------------------------------------------------------
\subsection{Model results}
%-------------------------------------------------------------------------------
% Figure mu across all species and climate predictors
\begin{figure}[!ht]
\includegraphics[width=0.8\textwidth]{../../analyses/figures/growthModelsMain/muALLbspp.jpeg}
\caption{Model slope parameters across the different model predictors for Wildchrokie species. GDD represent the accumulated growing degree days between leafout and budset (a) the models estimates shows log ring width change per 10 average spring days GDD (174). GSL is the number of days between leafout and budset (b). SOS represent the start of season, which is leafout (c) and EOS, the end of season through budset (d). All predictors were fit using the same model and number of observations, with only the independent variable changing (see Figure \ref{fig:wcSOSEOScomparison}a for a comparison between two different data set length for SOS, and Figure \ref{fig:wcSOSEOScomparison}b, for end of EOS). The dots represent the mean of the posterior distribution, the thick lines the 50\% uncertainty intervals (UI) and the thinner lines, the 90\% UI. The pannels on the right are the reconstructed species estimates posterior distribution with error at each GDD(e), GSL(f), SOS(g) and EOS (h) values. The lines represent the mean of the posterior distribution and the shaded area, the 50\% UI.}
\label{fig:wcmuplotbspp}
\end{figure}

\begin{enumerate}

% GDD
\item Growth did not change with greater thermal season for most species 
\Ainc: ($\beta = $ \Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Alnus incana")]}, $UI_{90}$[\Sexpr{bspp_df2$fit_bspp_per5[which(bspp_df2$spp_name %in% "Alnus incana")]}, \Sexpr{bspp_df2$fit_bspp_per95[which(bspp_df2$spp_name %in% "Alnus incana")]}]),
\Ball: ($\beta = $ 
\Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Betula alleghaniensis")]}, $UI_{90}$[\Sexpr{bspp_df2$fit_bspp_per5[which(bspp_df2$spp_name %in% "Betula alleghaniensis")]}, 
\Sexpr{bspp_df2$fit_bspp_per95[which(bspp_df2$spp_name %in% "Betula alleghaniensis")]}], and
\Bpop:  ($\beta = $ 
\Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Betula populifolia")]}, $UI_{90}$[\Sexpr{bspp_df2$fit_bspp_per5[which(bspp_df2$spp_name %in% "Betula populifolia")]}, 
\Sexpr{bspp_df2$fit_bspp_per95[which(bspp_df2$spp_name %in% "Betula populifolia")]}]].
However,
\Bpap grew more with longer thermal season ($\beta = $ 
\Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Betula papyrifera")]}, $UI_{90}$[\Sexpr{bspp_df2$fit_bspp_per5[which(bspp_df2$spp_name %in% "Betula papyrifera")]}, 
\Sexpr{bspp_df2$fit_bspp_per95[which(bspp_df2$spp_name %in% "Betula papyrifera")]}])) (Figure \ref{fig:wcmuplotbspp}a and e) (Table \ref{tab:wc_slope_table}).

% GSL
\item In contrast, most species grew more with longer calendar seasons 
(\Ainc: ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Alnus incana")]}, $UI_{90}$[\Sexpr{bspp_df2_gsl$fit_bspp_per5[which(bspp_df2_gsl$spp_name %in% "Alnus incana")]}, \Sexpr{bspp_df2_gsl$fit_bspp_per95[which(bspp_df2_gsl$spp_name %in% "Alnus incana")]}]),
\Ball: ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Betula alleghaniensis")]}, $UI_{90}$[\Sexpr{bspp_df2_gsl$fit_bspp_per5[which(bspp_df2_gsl$spp_name %in% "Betula alleghaniensis")]}, \Sexpr{bspp_df2_gsl$fit_bspp_per95[which(bspp_df2_gsl$spp_name %in% "Betula alleghaniensis")]}]) and
\Bpap: ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Betula papyrifera")]}, $UI_{90}$[\Sexpr{bspp_df2_gsl$fit_bspp_per5[which(bspp_df2_gsl$spp_name %in% "Betula papyrifera")]}, \Sexpr{bspp_df2_gsl$fit_bspp_per95[which(bspp_df2_gsl$spp_name %in% "Betula papyrifera")]}]).
Similarly to its response to the thermal season,
\Bpop did not grow more with longer calendar seasons ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Betula populifolia")]}, $UI_{90}$[\Sexpr{bspp_df2_gsl$fit_bspp_per5[which(bspp_df2_gsl$spp_name %in% "Betula populifolia")]}, \Sexpr{bspp_df2_gsl$fit_bspp_per95[which(bspp_df2_gsl$spp_name %in% "Betula populifolia")]}])
(Figure \ref{fig:wcmuplotbspp}b and f) (Table \ref{tab:wc_slope_table}).

% SOS
\item Growth decreased with a later start of season (SOS) for
\Ainc: $\beta = $ \Sexpr{bspp_df2_sos$fit_bspp[which(bspp_df2_sos$spp_name %in% "Alnus incana")]}, $UI_{90}$[\Sexpr{bspp_df2_sos$fit_bspp_per5[which(bspp_df2_sos$spp_name %in% "Alnus incana")]}, \Sexpr{bspp_df2_sos$fit_bspp_per95[which(bspp_df2_sos$spp_name %in% "Alnus incana")]}]) and 
\Bpop ($\beta = $ \Sexpr{bspp_df2_sos$fit_bspp[which(bspp_df2_sos$spp_name %in% "Betula populifolia")]}, $UI_{90}$[\Sexpr{bspp_df2_sos$fit_bspp_per5[which(bspp_df2_sos$spp_name %in% "Betula populifolia")]}, \Sexpr{bspp_df2_sos$fit_bspp_per95[which(bspp_df2_sos$spp_name %in% "Betula populifolia")]}]), but didn't change for the other two species
(\Ball ($\beta = $ \Sexpr{bspp_df2_sos$fit_bspp[which(bspp_df2_sos$spp_name %in% "Betula alleghaniensis")]}, $UI_{90}$[\Sexpr{bspp_df2_sos$fit_bspp_per5[which(bspp_df2_sos$spp_name %in% "Betula alleghaniensis")]}, \Sexpr{bspp_df2_sos$fit_bspp_per95[which(bspp_df2_sos$spp_name %in% "Betula alleghaniensis")]}]) and
\Bpap ($\beta = $ \Sexpr{bspp_df2_sos$fit_bspp[which(bspp_df2_sos$spp_name %in% "Betula papyrifera")]}, $UI_{90}$[\Sexpr{bspp_df2_sos$fit_bspp_per5[which(bspp_df2_sos$spp_name %in% "Betula papyrifera")]}, \Sexpr{bspp_df2_sos$fit_bspp_per95[which(bspp_df2_sos$spp_name %in% "Betula papyrifera")]}])) (Figure \ref{fig:wcmuplotbspp}c and g). The estimates were unchanged when using the full or restricted datasets ($n =$\Sexpr{nrow(empfullsos)} vs $n=$\Sexpr{nrow(emp)} Figure \ref{fig:wcSOSEOScomparison}a) (Table \ref{tab:wc_slope_table}). 

% EOS
\item Growth decreased with a later end of season (EOS) only for for 
\Ainc ($\beta = $ \Sexpr{bspp_df2_eos$fit_bspp[which(bspp_df2_eos$spp_name %in% "Alnus incana")]}, $UI_{90}$[\Sexpr{bspp_df2_eos$fit_bspp_per5[which(bspp_df2_eos$spp_name %in% "Alnus incana")]}, \Sexpr{bspp_df2_eos$fit_bspp_per95[which(bspp_df2_eos$spp_name %in% "Alnus incana")]}]). 
Growth did not change for the other species
(\Bpop: ($\beta = $ \Sexpr{bspp_df2_eos$fit_bspp[which(bspp_df2_eos$spp_name %in% "Betula populifolia")]}, $UI_{90}$[\Sexpr{bspp_df2_eos$fit_bspp_per5[which(bspp_df2_eos$spp_name %in% "Betula populifolia")]}, \Sexpr{bspp_df2_eos$fit_bspp_per95[which(bspp_df2_eos$spp_name %in% "Betula populifolia")]}], 
\Ball ($\beta = $ \Sexpr{bspp_df2_eos$fit_bspp[which(bspp_df2_eos$spp_name %in% "Betula alleghaniensis")]}, $UI_{90}$[\Sexpr{bspp_df2_eos$fit_bspp_per5[which(bspp_df2_eos$spp_name %in% "Betula alleghaniensis")]}, \Sexpr{bspp_df2_eos$fit_bspp_per95[which(bspp_df2_eos$spp_name %in% "Betula alleghaniensis")]}]) and
\Bpap ($\beta = $ \Sexpr{bspp_df2_eos$fit_bspp[which(bspp_df2_eos$spp_name %in% "Betula papyrifera")]}, $UI_{90}$[\Sexpr{bspp_df2_eos$fit_bspp_per5[which(bspp_df2_eos$spp_name %in% "Betula papyrifera")]}, \Sexpr{bspp_df2_eos$fit_bspp_per95[which(bspp_df2_eos$spp_name %in% "Betula papyrifera")]}]) (Figure \ref{fig:wcmuplotbspp}d and g). The estimates were unchanged when using the full or restricted datasets ($n =$\Sexpr{nrow(empfulleos)} vs $n=$\Sexpr{nrow(emp)} (Figure \ref{fig:wcSOSEOScomparison}b) (Table \ref{tab:wc_slope_table}). 

% Site
\item Growth did not change across any sites ( 
S. Hypolyte ($\alpha_{site} = $ \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "SH")]}, $UI_{90}$[\Sexpr{site_df2$fit_a_site_per5[which(site_df2$site_name %in% "SH")]}, \Sexpr{site_df2$fit_a_site_per95[which(site_df2$site_name %in% "SH")]}]),
D. College ($\alpha_{site} = $ \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "GR")]}, $UI_{90}$[\Sexpr{site_df2$fit_a_site_per5[which(site_df2$site_name %in% "GR")]}, \Sexpr{site_df2$fit_a_site_per95[which(site_df2$site_name %in% "GR")]}]), 
W. Mountains ($\alpha_{site} = $ \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "WM")]}, $UI_{90}$[\Sexpr{site_df2$fit_a_site_per5[which(site_df2$site_name %in% "WM")]}, \Sexpr{site_df2$fit_a_site_per95[which(site_df2$site_name %in% "WM")]}]) and 
H. Forest ($\alpha_{site} = $ = \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "HF")]}, $UI_{90}$[\Sexpr{site_df2$fit_a_site_per5[which(site_df2$site_name %in% "HF")]}, \Sexpr{site_df2$fit_a_site_per95[which(site_df2$site_name %in% "HF")]}]) (Figure \ref{fig:wcmuplotasite}) (Table \ref{tab:wc_asite_table}).

% Wildchrokie site mu plot
\begin{figure}[!ht]
\includegraphics[width=1\textwidth]{../../analyses/figures/growthModelsMain/asiteMap.pdf}
\caption{The effect of sites on growth across a latitudinal gradient. (a) Model intercept parameters for each site with growing degree days (GDD) as the predictor. The dots represent the mean of the posterior distribution, the thick lines the 50\% uncertainty intervals (UI) and the thinner lines, the 90\% UI. The sites are color-coded from (b), th map showing their locations.}
\label{fig:wcmuplotasite}
\end{figure}

% Effect size on standardized scale
\item The largest effect size across predictors varied considerably depending on species. We standardized the predictors through z-scoring to compare their respective effect size.
\Ball ($\beta = $
\Sexpr{max_ES$fit_bspp[which(max_ES$spp_name %in% "Betula alleghaniensis")]}, 
$UI_{90}$[\Sexpr{max_ES$fit_bspp_per5[which(max_ES$spp_name %in% "Betula alleghaniensis")]}, 
\Sexpr{max_ES$fit_bspp_per95[which(max_ES$spp_name %in% "Betula alleghaniensis")]}]) and
\Bpap ($\beta = $
\Sexpr{max_ES$fit_bspp[which(max_ES$spp_name %in% "Betula papyrifera")]}, 
$UI_{90}$[\Sexpr{max_ES$fit_bspp_per5[which(max_ES$spp_name %in% "Betula papyrifera")]}, 
\Sexpr{max_ES$fit_bspp_per95[which(max_ES$spp_name %in% "Betula papyrifera")]}]) responded most to GSL, and
\Ainc ($\beta = $
\Sexpr{max_ES$fit_bspp[which(max_ES$spp_name %in% "Alnus incana")]}, 
$UI_{90}$[\Sexpr{max_ES$fit_bspp_per5[which(max_ES$spp_name %in% "Alnus incana")]}, 
\Sexpr{max_ES$fit_bspp_per95[which(max_ES$spp_name %in% "Alnus incana")]}]) and
\Bpop ($\beta = $
\Sexpr{max_ES$fit_bspp[which(max_ES$spp_name %in% "Betula populifolia")]}, 
$UI_{90}$[\Sexpr{max_ES$fit_bspp_per5[which(max_ES$spp_name %in% "Betula populifolia")]}, 
\Sexpr{max_ES$fit_bspp_per95[which(max_ES$spp_name %in% "Betula populifolia")]}]) had the strongest response to SOS (Figure \ref{fig:bsppZscored}).

\end{enumerate}

% <><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><>
\section{CoringTreespotters}
% <><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><><>
%-------------------------------------------------------------------------------
\subsection{Species, years and observations}
%-------------------------------------------------------------------------------
\begin{enumerate}
\item CoringTreespotters includes eleven deciduous tree species with phenological observations from 2016 to 2024. In total, our final dataset has \Sexpr{nrow(empfullsosts)} leafout observations and \Sexpr{nrow(empfulleosts)}. We used these observations to set the boundaries of individual-level growing seasons, which together yield \Sexpr{nrow(empts)} complete growing season observations.
\end{enumerate}

%-------------------------------------------------------------------------------
\subsection{Growing season length and conditions}
%-------------------------------------------------------------------------------
\begin{enumerate}

% GSL length and conditions
\item Across our nine years, \Sexpr{gddsummersum[which.min(gddsummersum$gdddiff),1]}  had the lowest summer thermal sum (\Sexpr{gddsummersum[which.min(gddsummersum$gdddiff), 2]} GDD), and \Sexpr{gddsummersum[which.max(gddsummersum$gdddiff),1]} had the highest summer thermal sum (\Sexpr{gddsummersum[which.max(gddsummersum$gdddiff), 2]} GDD).
\item \Sexpr{pgsGSLaggTS[which.min(pgsGSLaggTS$pgsGSL),1]} was the shortest season by days (mean GSL $=$\Sexpr{pgsGSLaggTS[which.min(pgsGSLaggTS$pgsGSL),2]}),
with an average summer temperature of 
\Sexpr{climatesum[climatesum$period == "JJA" & climatesum$year == pgsGSLaggTS[which.min(pgsGSLaggTS$pgsGSL), 1], 5]}$^\circ$C, and a summer thermal sum of 
\Sexpr{gddsummersum[which(gddsummersum$year %in% pgsGSLaggTS[which.min(pgsGSLaggTS$pgsGSL),1]),2]} GDD. \\
\Sexpr{pgsGSLaggTS[which.max(pgsGSLaggTS$pgsGSL),1]} was the longest season by days (mean GSL $=$
\Sexpr{pgsGSLaggTS[which.max(pgsGSLaggTS$pgsGSL),2]})
with an average summer temperature of 
\Sexpr{climatesum[climatesum$period == "JJA" & climatesum$year == pgsGSLaggTS[which.max(pgsGSLaggTS$pgsGSL), 1], 5]}$^\circ$C, and a summer thermal sum of 
\Sexpr{gddsummersum[which(gddsummersum$year %in% pgsGSLaggTS[which.max(pgsGSLaggTS$pgsGSL),1]),2]} GDD. \\

% SOS conditions
\item Leafout dates across all years and species varied from 
\Sexpr{min(empts$leafout)} (\Sexpr{empts[which.min(empts$leafout),3]}) to 
\Sexpr{max(empts$leafout)} (\Sexpr{empts[which.max(empts$leafout),3]}) and leaf colouring date varied from 
\Sexpr{min(empts$coloredLeaves)} (\Sexpr{empts[which.min(empts$coloredLeaves),3]}) to 
\Sexpr{max(empts$coloredLeaves)} (\Sexpr{empts[which.max(empts$coloredLeaves),3]}).

\item \Sexpr{SOSaggTS[which.min(SOSaggTS$leafout),1]} had the earliest start of season (mean leafout date $=$
\Sexpr{SOSaggTS[which.min(SOSaggTS$leafout),2]}), an average temperature of (
\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == SOSaggTS[which.min(SOSaggTS$leafout), 1], 5]}$^\circ$C), and a spring thermal sum of 
\Sexpr{gddspringsum[which(gddspringsum$year %in% SOSaggTS[which.min(SOSaggTS$leafout),1]),2]} GDD. \\
\Sexpr{SOSaggTS[which.max(SOSaggTS$leafout),1]} had the latest start of season (mean leafout date $=$
\Sexpr{SOSaggTS[which.max(SOSaggTS$leafout),2]}), 
an average temperature of 
(\Sexpr{climatesum[climatesum$period == "MAM" & climatesum$year == SOSaggTS[which.max(SOSaggTS$leafout), 1], 5]}$^\circ$C), and a thermal sum of 
(\Sexpr{gddspringsum[which(gddspringsum$year %in% SOSaggTS[which.max(SOSaggTS$leafout),1]),2]} GDD). This year coincides with the shortest growing season and had the fourth earliest EOS \Sexpr{EOSaggTS[which(EOSaggTS$year %in% SOSaggTS[which.max(SOSaggTS$leafout),1]),2]}.\\

% SOS by species 
\item On average, the earliest leafout date for each species are
\Arub: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Acer rubrum"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Acer rubrum"]),1]}), 
\Asac: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Acer saccharum"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Acer saccharum"]),1]}), 
\Afla: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Aesculus flava"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Aesculus flava"]),1]}), 
\Ball: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Betula alleghaniensis"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Betula alleghaniensis"]),1]}), 
\Bnig: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Betula nigra"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Betula nigra"]),1]}), 
\Cgla: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Carya glabra"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Carya glabra"]),1]}), 
\Cova: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Carya ovata"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Carya ovata"]),1]}), 
\Pdel: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Populus deltoides"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Populus deltoides"]),1]}), 
\Qalb: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Quercus alba"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Quercus alba"]),1]}), 
\Qrub: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Quercus rubra"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Quercus rubra"]),1]}), 
\Tame: \Sexpr{min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Tilia americana"])} 
(\Sexpr{leafoutbyyrts[which.min(leafoutbyyrts$leafout[leafoutbyyrts$latbi == "Tilia americana"]),1]}), 

% EOS condition
\item \Sexpr{EOSaggTS[which.min(EOSaggTS$coloredLeaves),1]} had the earliest end of season (mean leaf colouring date $=$
\Sexpr{EOSaggTS[which.min(EOSaggTS$coloredLeaves),2]}), an average temperature of (
\Sexpr{climatesum[climatesum$period == "SON" & climatesum$year == EOSaggTS[which.min(EOSaggTS$coloredLeaves), 1], 5]}$^\circ$C), and an autumn thermal sum of 
\Sexpr{gddspringsum[which(gddspringsum$year %in% EOSaggTS[which.min(EOSaggTS$coloredLeaves),1]),2]} GDD. \\
\Sexpr{EOSaggTS[which.max(EOSaggTS$coloredLeaves),1]} had the latest end of season (mean leaf colouring date $=$
\Sexpr{EOSaggTS[which.max(EOSaggTS$coloredLeaves),2]}), 
an average temperature of 
(\Sexpr{climatesum[climatesum$period == "SON" & climatesum$year == EOSaggTS[which.max(EOSaggTS$coloredLeaves), 1], 5]}$^\circ$C), and an autumn thermal sum of 
(\Sexpr{gddspringsum[which(gddspringsum$year %in% EOSaggTS[which.max(EOSaggTS$coloredLeaves),1]),2]} GDD). \\

% EOS by species 

% PDSI spring
\item The driest spring of the nine years (MAM) (3-month averaged PDSI index) was
\Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} with a PDSI value of 
\Sexpr{climatesum$pdsi[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrts, climatesum$pdsi, NA))]}, a cumulative precipitation of 
\Sexpr{climatesum$ppt[which.min(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} mm.
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} was the least dry spring with a PDSI value of 
\Sexpr{climatesum$pdsi[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} and a cumulative precipitation of \Sexpr{climatesum$ppt[which.max(ifelse(climatesum$period == "MAM" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} mm.

% PDSI summer
\item \Sexpr{climatesum$year[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} also had the driest summer (JJA) with a PDSI value of 
\Sexpr{climatesum$pdsi[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrts, climatesum$pdsi, NA))]}, and a cumulative precipitation of 
\Sexpr{climatesum$ppt[which.min(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} mm.
\Sexpr{climatesum$year[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} was the least dry summer with a PDSI value of 
\Sexpr{climatesum$pdsi[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} and a cumulative precipitation of 
\Sexpr{climatesum$ppt[which.max(ifelse(climatesum$period == "JJA" & climatesum$year %in% yrts, climatesum$pdsi, NA))]} mm.

% Drought occurence
\item \Sexpr{unique(moderatedrought[which(moderatedrought$month <10 & moderatedrought$month > 2 & moderatedrought$year %in% yrts), 1])} had at least one month of moderate drought ($PDSI [-3, -2]$) throughout their growing seasons.
Severe droughts periods occurred in \Sexpr{unique(severedrought[which(severedrought$month <10 & severedrought$month > 2 & severedrought$year %in% yrts), 1])} for at least one month ($PDSI < -3$).

\end{enumerate}

%-------------------------------------------------------------------------------
\subsection{Ring widths}
%-------------------------------------------------------------------------------
\begin{enumerate}
\item The ring widths of our species---for the study period---vary from \Sexpr{min(empts$lengthMM)} mm to \Sexpr{max(empts$lengthMM)} mm. 
\item Ring widths for \Cova were the smallest and varied from 
\Sexpr{rwsumts[which(rwsumts$latbi %in% rwsumts[which.min(rwsumts$mean), 1]), 2]} mm to 
\Sexpr{rwsumts[which(rwsumts$latbi %in% rwsumts[which.min(rwsumts$mean), 1]), 3]} mm, and 
\Asac had the largest rings which spanned from 
\Sexpr{rwsumts[which(rwsumts$latbi %in% rwsumts[which.max(rwsumts$mean), 1]), 2]} to
\Sexpr{rwsumts[which(rwsumts$latbi %in% rwsumts[which.max(rwsumts$mean), 1]), 3]}.
\end{enumerate}

%-------------------------------------------------------------------------------
\subsection{Model results}
%-------------------------------------------------------------------------------

% Figure mu across all species and climate predictors
\begin{figure}[!ht]
\includegraphics[width=0.8\textwidth]{/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/figures/growthModelsMain/muALLbsppWlines.jpeg}
\caption{Model slope parameters across the different model predictors for CoringTreespotters species. GDD represent the accumulated growing degree days between leafout and leaf colouring  (a) the models estimates shows log ring width change per 10 average spring days GDD (174). GSL is the number of days between leafout and leaf colouring (b). SOS represents the start of season, which is leafout (c) and EOS, the end of season through budset (d). All predictors were fit using the same model and number of observations, with only the independent variable changing (see Figure \ref{fig:tsSOSEOScomparison}a for a comparison between two different data set length for SOS, and Figure \ref{fig:tsSOSEOScomparison}b, for end of EOS). The dots represent the mean of the posterior distribution, the thick lines the 50\% uncertainty intervals (UI) and the thinner lines, the 90\% UI. The pannels on the right are the reconstructed species estimates posterior distribution with error at each GDD(e), GSL(f), SOS(g) and EOS (h) values. The lines represent the mean of the posterior distribution and the shaded area, the 50\% UI.}
\label{fig:wcmuplotbsppTS}
\end{figure}

\begin{enumerate}

% GDD
\item Growth did not change with greater thermal season for most species 
(\Arub: $\beta = $ \Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Acer rubrum")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Acer rubrum")]}, \Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Acer rubrum")]}],
\Asac: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Acer saccharum")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Acer saccharum")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Acer saccharum")]}],
\Afla: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Aesculus flava")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Aesculus flava")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Aesculus flava")]}],
\Bnig: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Betula nigra")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Betula nigra")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Betula nigra")]}],
\Cgla: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Carya glabra")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Carya glabra")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Carya glabra")]}],
\Cova: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Carya ovata")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Carya ovata")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Carya ovata")]}],
\Pdel: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Populus deltoides")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Populus deltoides")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Populus deltoides")]}],
\Qalb: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Quercus alba")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Quercus alba")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Quercus alba")]}],
\Qrub: $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Quercus rubra")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Quercus rubra")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Quercus rubra")]}],
\Tame $\beta = $
\Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Tilia americana")]}, $UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Tilia americana")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Tilia americana")]}]). 
However, growth for \Ball decreased with greater thermal season 
$\beta = $ \Sexpr{bspp_df2_ts$fit_bspp[which(bspp_df2_ts$spp_name %in% "Betula alleghaniensis")]}, 
$UI_{90}$[\Sexpr{bspp_df2_ts$fit_bspp_per5[which(bspp_df2_ts$spp_name %in% "Betula alleghaniensis")]},
\Sexpr{bspp_df2_ts$fit_bspp_per95[which(bspp_df2_ts$spp_name %in% "Betula alleghaniensis")]}])
) (Figure \ref{fig:wcmuplotbsppTS}a and e). These estimates were unchanged when using budburst instead of leafout as  the start of the growing season (Figure \ref{fig:buburstVSleafoutTS}a) (Table \ref{tab:ts_slope_table}).
 
% GSL
\item Similarly to the response to thermal season, the species did not increase growth with longer calendar season 
(\Arub: $\beta = $ \Sexpr{bspp_df2_ts_gsl$fit_bspp[which(bspp_df2_ts_gsl$spp_name %in% "Acer rubrum")]}, $UI_{90}$[\Sexpr{bspp_df2_ts_gsl$fit_bspp_per5[which(bspp_df2_ts_gsl$spp_name %in% "Acer rubrum")]}, \Sexpr{bspp_df2_ts_gsl$fit_bspp_per95[which(bspp_df2_ts_gsl$spp_name %in% "Acer rubrum")]}],
\Asac: $\beta = $
