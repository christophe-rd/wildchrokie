\Sexpr{bspp_df2_ts_eos$fit_bspp_per95[which(bspp_df2_ts_eos$spp_name %in% "Tilia americana")]}]))
, except \Ball for which its growth decreased with later end of season ($\beta = $
\Sexpr{bspp_df2_ts_eos$fit_bspp[which(bspp_df2_ts_eos$spp_name %in% "Betula alleghaniensis")]}, $UI_{90}$[\Sexpr{bspp_df2_ts_eos$fit_bspp_per5[which(bspp_df2_ts_eos$spp_name %in% "Betula alleghaniensis")]},
\Sexpr{bspp_df2_ts_eos$fit_bspp_per95[which(bspp_df2_ts_eos$spp_name %in% "Betula alleghaniensis")]}]) (Figure \ref{fig:wcmuplotbsppTS}d and h). The estimates were unchanged when using the full or restricted datasets ($n =$\Sexpr{nrow(empfulleosts)} vs $n=$\Sexpr{nrow(empts)} Figure \ref{fig:tsSOSEOScomparison}b) (Table \ref{tab:ts_slope_table}).

% Effect size across species
\item Tough we report an effect only for \Ball, we standardized the predictors through z-scoring to compare their respective effect size. 
\Asac ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Acer saccharum")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Acer saccharum")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Acer saccharum")]}]),
\Ball ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Betula alleghaniensis")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Betula alleghaniensis")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Betula alleghaniensis")]}]),
\Cova ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Carya ovata")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Carya ovata")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Carya ovata")]}]) and
\Pdel ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Populus deltoides")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Populus deltoides")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Populus deltoides")]}]) responded most to GDD,
\Arub ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Acer rubrum")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Acer rubrum")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Acer rubrum")]}]),
\Afla ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Aesculus flava")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Aesculus flava")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Aesculus flava")]}]),
\Bnig ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Betula nigra")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Betula nigra")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Betula nigra")]}]) and
\Tame ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Tilia americana")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Tilia americana")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Tilia americana")]}]) had the strongest response to SOS, and to EOS for
\Cgla ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Carya glabra")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Carya glabra")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Carya glabra")]}]),
\Qalb ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Quercus alba")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Quercus alba")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Quercus alba")]}]) and
\Qrub ($\beta = $
\Sexpr{max_ES_ts$fit_bspp[which(max_ES_ts$spp_name %in% "Quercus rubra")]}, 
$UI_{90}$[\Sexpr{max_ES_ts$fit_bspp_per5[which(max_ES_ts$spp_name %in% "Quercus rubra")]}, 
\Sexpr{max_ES_ts$fit_bspp_per95[which(max_ES_ts$spp_name %in% "Quercus rubra")]}]). No species responsed most to GSL (Figure \ref{fig:bsppZscoredTS}).

\end{enumerate}
