%-------------------------------------------------------------------------------
\subsection{Growing season length and conditions}
%-------------------------------------------------------------------------------
\begin{enumerate}

% GSL length
\item Across the three years and all species, the growing season length varied from \Sexpr{min(emp$pgsGSL)} days to \Sexpr{max(emp$pgsGSL)} days. 

% GSL length
\item The year with longest growing season length on average was 
\Sexpr{aggregate(pgsGSL ~ year, emp, mean)[which.max(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),1]} 
with
\Sexpr{round(aggregate(pgsGSL ~ year, emp, mean)[which.max(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),2], 2)} days,
and the shortest was 
\Sexpr{aggregate(pgsGSL ~ year, emp, mean)[which.min(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),1]} 
with
\Sexpr{round(aggregate(pgsGSL ~ year, emp, mean)[which.min(aggregate(pgsGSL ~ year, emp, mean)$pgsGSL),2], 2)} days.

% Temperature spring
\item The hottest spring period of the three years (MAM) was 
\Sexpr{climatesum$year[which(climatesum$tmeanmean_MAM %in% max(climatesum$tmeanmean_MAM[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$tmeanmean_MAM[which(climatesum$tmeanmean_MAM %in% max(climatesum$tmeanmean_MAM[which(climatesum$year %in% yrwc)]))], 2)}$^\circ$C,
and the coldest, 
\Sexpr{climatesum$year[which(climatesum$tmeanmean_MAM %in% min(climatesum$tmeanmean_MAM[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$tmeanmean_MAM[which(climatesum$tmeanmean_MAM %in% min(climatesum$tmeanmean_MAM[which(climatesum$year %in% yrwc)]))], 2)}$^\circ$C. 

% Temperature summer
\item The hottest summer period of the three years (JJA) was 
\Sexpr{climatesum$year[which(climatesum$tmeanmean_JJA %in% max(climatesum$tmeanmean_JJA[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$tmeanmean_JJA[which(climatesum$tmeanmean_JJA %in% max(climatesum$tmeanmean_JJA[which(climatesum$year %in% yrwc)]))], 2)}$^\circ$C,
and the coldest, 
\Sexpr{climatesum$year[which(climatesum$tmeanmean_JJA %in% min(climatesum$tmeanmean_JJA[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$tmeanmean_JJA[which(climatesum$tmeanmean_JJA %in% min(climatesum$tmeanmean_JJA[which(climatesum$year %in% yrwc)]))], 2)}$^\circ$C. 

% PDSI spring
\item The driest spring period of the three years (MAM) was 
\Sexpr{climatesum$year[which(climatesum$pdsi_MAM %in% max(climatesum$pdsi_MAM[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$pdsi_MAM[which(climatesum$pdsi_MAM %in% max(climatesum$pdsi_MAM[which(climatesum$year %in% yrwc)]))], 2)},
and the coldest, 
\Sexpr{climatesum$year[which(climatesum$pdsi_MAM %in% min(climatesum$pdsi_MAM[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$pdsi_MAM[which(climatesum$pdsi_MAM %in% min(climatesum$pdsi_MAM[which(climatesum$year %in% yrwc)]))], 2)}. 

% PDSI summer
\item The driest summer period (PDSI) of the three years (JJA) was 
\Sexpr{climatesum$year[which(climatesum$pdsi_JJA %in% max(climatesum$pdsi_JJA[which(climatesum$year %in% yrwc)]))]} with a PDSI value of \Sexpr{round(climatesum$pdsi_JJA[which(climatesum$pdsi_JJA %in% max(climatesum$pdsi_JJA[which(climatesum$year %in% yrwc)]))], 2)},
and the coldest, 
\Sexpr{climatesum$year[which(climatesum$pdsi_JJA %in% min(climatesum$pdsi_JJA[which(climatesum$year %in% yrwc)]))]} with a PDSI value of \Sexpr{round(climatesum$pdsi_JJA[which(climatesum$pdsi_JJA %in% min(climatesum$pdsi_JJA[which(climatesum$year %in% yrwc)]))], 2)}. 

% PPT spring
\item The spring period with the highest precipitation of the three years (MAM) was 
\Sexpr{climatesum$year[which(climatesum$ppt_MAM %in% max(climatesum$ppt_MAM[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$ppt_MAM[which(climatesum$ppt_MAM %in% max(climatesum$ppt_MAM[which(climatesum$year %in% yrwc)]))], 2)},
and the coldest, 
\Sexpr{climatesum$year[which(climatesum$ppt_MAM %in% min(climatesum$ppt_MAM[which(climatesum$year %in% yrwc)]))]} with a mean mean temperature of \Sexpr{round(climatesum$ppt_MAM[which(climatesum$ppt_MAM %in% min(climatesum$ppt_MAM[which(climatesum$year %in% yrwc)]))], 2)}. 

% PPT summer
\item The summer period with the highest precipitation of the three years (JJA) was 
\Sexpr{climatesum$year[which(climatesum$ppt_JJA %in% max(climatesum$ppt_JJA[which(climatesum$year %in% yrwc)]))]} with a PDSI value of \Sexpr{round(climatesum$ppt_JJA[which(climatesum$ppt_JJA %in% max(climatesum$ppt_JJA[which(climatesum$year %in% yrwc)]))], 2)},
and the coldest, 
\Sexpr{climatesum$year[which(climatesum$ppt_JJA %in% min(climatesum$ppt_JJA[which(climatesum$year %in% yrwc)]))]} with a PDSI value of \Sexpr{round(climatesum$ppt_JJA[which(climatesum$ppt_JJA %in% min(climatesum$ppt_JJA[which(climatesum$year %in% yrwc)]))], 2)}. 

\end{enumerate}

<<my_table, results='asis', echo=FALSE>>=
  climatesum
kable(climatesum, caption = "Sample Fruit Prices", booktabs = TRUE)
@
  \end{enumerate}
  
%-------------------------------------------------------------------------------
\subsection{Ring widths}
%-------------------------------------------------------------------------------
\begin{enumerate}
\item The ring width of our species vary from \Sexpr{round(min(emp$lengthMM),2)}mm to \Sexpr{round(max(emp$lengthMM),2)}mm. 
\end{enumerate}

%-------------------------------------------------------------------------------
\subsection{Model results}
%-------------------------------------------------------------------------------
Our results show similar trends in response to the thermal versus the calendar growing season, with a slightly stronger response to longer growing season compared to the increased growing degree days. 

% Figure Growth X GDD
\begin{figure}[!ht]
\includegraphics[width=1\textwidth]{../../analyses/figures/empiricalData/growthModelSlopesperSppFacet.jpeg}
\caption{Ring width responses to growing degree days for the primary growing season. The shaded areas represent the 50\% confidence intervals. The dots represent the empirical data}
\label{fig:wcgrowthSlopes}
\end{figure}

\begin{enumerate}
% GDD
\item G. alder ($\beta = $ \Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Grey alder")]}),
Y. birch ($\beta = $ \Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Yellow birch")]}) and
P. Birch ($\beta = $ \Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Paper birch")]}) 
show a weak response, but seem to grow more with more GDD, while 
G. birch  ($\beta = $ \Sexpr{bspp_df2$fit_bspp[which(bspp_df2$spp_name %in% "Gray birch")]})  
did not respond to increased GDD 
(Figure \ref{fig:wcmuplotbsppGDD}).

% Figure mu plot bspp GDD
\begin{figure}[!ht]
\includegraphics[width=0.5\textwidth]{../../analyses/figures/empiricalData/bspp_mean_plot.jpeg}
\caption{Slope values across the different species for GDD}
\label{fig:wcmuplotbsppGDD}
\end{figure}

% GSL
\item G. alder ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Grey alder")]}) is the only species for which its 90\% intervals don't overlap with zero. 
Y. birch ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Yellow birch")]}) and
P. Birch ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Paper birch")]}) 
show a weaker response, but seem to grow more in response to longer seasons, while 
G. birch  ($\beta = $ \Sexpr{bspp_df2_gsl$fit_bspp[which(bspp_df2_gsl$spp_name %in% "Gray birch")]})  
did not respond to the GSL 
(Figure \ref{fig:wcmuplotbsppGSL}).

\item For the provenance with the GDD model, we detected a weak growth difference between 
G. College ($\alpha_{site} = $ \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "GR")]}), 
S. Hypolyte ($\alpha_{site} = $ \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "SH")]}) or 
W. Mountains ($\alpha_{site} = $ \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "WM")]}).
Only HF grew less ($\alpha_{site} = $ = \Sexpr{site_df2$fit_a_site[which(site_df2$site_name %in% "HF")]}) 
(Figure \ref{fig:wcmuplotbsppasite})


\end{enumerate}

