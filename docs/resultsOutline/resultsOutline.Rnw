\renewcommand{\thetable}{S\arabic{table}}
\setcounter{figure}{0}
\renewcommand{\thefigure}{S\arabic{figure}}

\begin {enumerate}
\item Fitting start of season (leafout) adds \Sexpr{nrow(empfull[!is.na(empfull$leafout),]) - nrow(empfull[!is.na(empfull$pgsGDD5),])} rows of data out of the \Sexpr{nrow(empfull[!is.na(empfull$pgsGDD5),])} when removing both NA entries for leafout and budset, and \Sexpr{nrow(empfull[!is.na(empfull$budset),]) - nrow(empfull[!is.na(empfull$pgsGDD5),])} rows of data when fitting the full dataset of end of season (budset).
\item Fitting with the maximum number of rows of data didn't change the parameter estimates by much for SOS (Figure \ref{fig:wcSOScomparison}) and EOS (Figure \ref{fig:wcEOScomparison}).
\end {enumerate}

% SOS data comparison
\begin{figure}[!ht]
\includegraphics[width=1\textwidth]{../../analyses/figures/empiricalData/SOSFullVSRestricted.jpeg}
\caption{Full vs most restricted rows of data for the model with SOS as the predictor. Each pannel represent the different parameters used to fit the models.}
\label{fig:wcSOScomparison}
\end{figure}

% EOS data comparison 
\begin{figure}[!ht]
\includegraphics[width=1\textwidth]{../../analyses/figures/empiricalData/EOSFullVSRestricted.jpeg}
\caption{Full vs most restricted rows of data for the model with EOS as the predictor. Each pannel represent the different parameters used to fit the models.}
\label{fig:wcEOScomparison}
\end{figure}

% Leafout X climate predictors
\begin{figure}[!ht]
\includegraphics[width=0.7\textwidth]{../../analyses/figures/climate/climSumLeafout.jpeg}
\caption{Leafout as a function of different climate predictors across winter (DJF) and spring (MAM). DJF is for December, January and February and MAM is for March, April and May. PDSI represents the Palmer Drought Severity Index averaged for each period. TempMeanMax, TempMeanMean and TempMeanMin are the averaged maximum, mean and mininimum monthly temperature over the 3-month periods. Precip is the total precipitation (mm) received over the 3-month periods.}
\label{fig:leafoutClim}
\end{figure}

% Budset X climate predictors
\begin{figure}[!ht]
\includegraphics[width=0.7\textwidth]{../../analyses/figures/climate/climSumBudset.jpeg}
\caption{Budset as a function of different climate predictors across spring (MAM), summer (JJA) and autumn (SON). MAM is for March, April and May, JJA is for June, July and August and SON is for September, October and November. PDSI represents the Palmer Drought Severity Index averaged for each period. TempMeanMax, TempMeanMean and TempMeanMin are the averaged maximum, mean and mininimum monthly temperature over the 3-month periods. Precip is the total precipitation (mm) received over the 3-month periods.}
\label{fig:budsetClim}
\end{figure}

% Climate lmer output
<<Code_chunk_Minimal_example, results='asis', echo=FALSE>>=
separator <- data.frame(predictor="", period="", slope=NA,
                        std_error=NA, t_value=NA, p_value=NA)

combined <- rbind(climresultsleafout, separator, climresultsbudset)

strCaption <- paste0("\\ Regression coefficients for the lmer model with years as random effects.")

print(xtable(combined, digits=2, caption=strCaption, label="tab:climResults"),
      size="footnotesize",
      include.rownames=FALSE,
      include.colnames=FALSE,
      caption.placement="top",
      hline.after=NULL,
      sanitize.text.function = identity,      
      add.to.row = list(
        pos = list(-1,                        
                   nrow(climresultsleafout),  
                   nrow(combined)),           
        command = c(
          #header
          paste("\\toprule \n",
                "Predictor & Season & Slope & Std.\\ Error & $t$-value & $p$-value \\\\\n",
                "\\midrule \n",
                # leafout sub-header
                "\\multicolumn{6}{l}{\\textit{leafout}} \\\\\n",
                "\\midrule \n"),
          # separators
          paste("\\midrule \n",
                "\\multicolumn{6}{l}{\\textit{budset}} \\\\\n",
                "\\midrule \n"),
          #footer?
          "\\bottomrule \n"
        )
      )
)

@

