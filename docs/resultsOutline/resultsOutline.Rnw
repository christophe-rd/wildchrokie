<<setup, echo=FALSE, message=FALSE, warning=FALSE>>=
library(xtable)
source("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/rcode/growthModelsMain_plots.R")
source("/Users/christophe_rouleau-desrochers/github/wildchrokie/analyses/rcode/climate_plots.R")
source("/Users/christophe_rouleau-desrochers/github/coringtreespotters/analyses/rcode/TSgrowthModelsMain_plots.R")

options(digits = 1)

# get some useful objects
pgsGSLagg <- aggregate(pgsGSL ~ year, emp, mean)
pgsGSLaggTS <- aggregate(pgsGSL ~ year, empts, mean)
pgsGSLaggTS <- subset(pgsGSLaggTS, year != 2015)
SOSagg <- aggregate(leafout ~ year, emp, mean)
SOSaggTS <- aggregate(leafout ~ year, empts, mean)
SOSaggTS <- subset(SOSaggTS, year != 2015)
EOSagg <- aggregate(budset ~ year, emp, mean)
EOSaggTS <- aggregate(coloredLeaves ~ year, empts, mean)
EOSaggTS <- subset(EOSaggTS, year != 2015)

# JJA thermal sum
temp <- subset(gddyr, doy >59 & doy < 152)
temp$mingddperiod <- ave(temp$GDD_5, temp$year, FUN = min)
temp$gdddiff <- temp$GDD_5 - temp$mingddperiod

gddspringsum <- aggregate(gdddiff ~ year, temp, FUN = max)

# JJA thermal sum
temp <- subset(gddyr, doy >152 & doy < 244)
temp$mingddperiod <- ave(temp$GDD_5, temp$year, FUN = min)
temp$gdddiff <- temp$GDD_5 - temp$mingddperiod
temp <- subset(temp, year != 2015)
gddsummersum <- aggregate(gdddiff ~ year, temp, FUN = max)

# JJA thermal sum
temp <- subset(gddyr, doy >243 & doy < 305)
temp$mingddperiod <- ave(temp$GDD_5, temp$year, FUN = min)
temp$gdddiff <- temp$GDD_5 - temp$mingddperiod

gddautumnsum <- aggregate(gdddiff ~ year, temp, FUN = max)

# Climate summary table
climatesum2 <- climatesum[, 1:6]
climatesum2 <- climatesum2[climatesum2$period %in% "JJA", ]

merged_data <- merge(pgsGSLaggTS, SOSaggTS, by = "year", all = TRUE)
merged_data <- merge(merged_data, EOSaggTS, by = "year", all = TRUE)
merged_data <- merge(merged_data, gddsummersum, by = "year", all = TRUE)
phenoclimatefortable <- merge(merged_data, climatesum2[,c(1,3:6)], by = "year", all = TRUE)
phenoclimatefortable

# get the model dfs
aspp_df5 <- aspp_df2[, c("spp_name", "fit_aspp_per5", "fit_aspp_per25","fit_aspp_per75","fit_aspp_per95")]
aspp_df5_gsl <- aspp_df2_gsl[, c("spp_name", "fit_aspp_per5", "fit_aspp_per25","fit_aspp_per75","fit_aspp_per95")]
aspp_df5_sos <- aspp_df2_sos[, c("spp_name", "fit_aspp_per5", "fit_aspp_per25","fit_aspp_per75","fit_aspp_per95")]
aspp_df5_eos <- aspp_df2_eos[, c("spp_name", "fit_aspp_per5", "fit_aspp_per25","fit_aspp_per75","fit_aspp_per95")]

site_df5 <-         site_df2[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]
site_df5_gsl <- site_df2_gsl[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]
site_df5_sos <- site_df2_sos[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]
site_df5_eos <- site_df2_eos[, c("site_name", "fit_a_site_per5", "fit_a_site_per25","fit_a_site_per75","fit_a_site_per95")]

bspp_df5 <-         bspp_df2[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]
bspp_df5_gsl <- bspp_df2_gsl[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]
bspp_df5_sos <- bspp_df2_sos[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]
bspp_df5_eos <- bspp_df2_eos[, c("spp_name", "fit_bspp_per5", "fit_bspp_per25","fit_bspp_per75","fit_bspp_per95")]

climatesumfortable <- climatesum[which(climatesum$year %in% yrwc), 1:7]
@

