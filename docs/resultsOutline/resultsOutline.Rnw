% Figure mu plot bspp GSL
\begin{figure}[!ht]
\includegraphics[width=0.5\textwidth]{../../analyses/figures/empiricalData/bspp_mean_plotGSL.jpeg}
\caption{Slope values across the different species for GDD}
\label{fig:wcmuplotbsppGSL}
\end{figure}


